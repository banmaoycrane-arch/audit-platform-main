# 复制本文件为 deploy/.env 并填写后再启动：cp deploy/.env.example deploy/.env

# 【必填】登录令牌(JWT)签名密钥，请使用随机长字符串，切勿外泄或提交到仓库。
# 生成方法（在服务器执行）：openssl rand -hex 32
SECRET_KEY=

# 【可选】大模型 API（OpenAI 兼容）。留空则系统使用降级的规则/模板，核心功能不受影响。
# 三项需配套填写；上线后再填即可，key 只存在服务器本地、不进代码仓库。
#   AI_BASE_URL 填到 /v1 为止、结尾不要带斜杠，例如 https://api.openai.com/v1
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# 【税务城市出口 IP 池】合作商代理配置
# 生产环境建议关闭演示种子，改用手动 SQL 导入合作商真实 IP（见 deploy/sql/seed_tax_egress_partner.sql）
TAX_EGRESS_SEED_ENABLED=false
TAX_EGRESS_MAX_ROTATE_PER_TAXPAYER_7D=2
TAX_EGRESS_COOLING_HOURS=24
TAX_EGRESS_DEFAULT_LEASE_DAYS=90
