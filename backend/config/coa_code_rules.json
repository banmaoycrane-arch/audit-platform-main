{
  "version": "1.0.0",
  "levels": [
    {
      "level": 1,
      "segment_length": 4,
      "min_code": "1000",
      "max_code": "9999",
      "pattern": "^\\d{4}$",
      "description": "一级科目"
    },
    {
      "level": 2,
      "segment_length": 2,
      "min_code": "01",
      "max_code": "99",
      "pattern": "^\\d{2}$",
      "description": "二级科目"
    },
    {
      "level": 3,
      "segment_length": 2,
      "min_code": "01",
      "max_code": "99",
      "pattern": "^\\d{2}$",
      "description": "三级科目"
    }
