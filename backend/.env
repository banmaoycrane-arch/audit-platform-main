# =============================================================================
# 财务向量审计系统 - 配置文件
# =============================================================================

# 安全密钥（生产环境必须更改）
SECRET_KEY=local-development-secret-key-change-before-production

# =============================================================================
# 数据库配置
# =============================================================================
# 数据库连接URL，默认为SQLite本地数据库
# 支持 PostgreSQL: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://admin:password@localhost:5432/finance_audit

# =============================================================================
# AI 模型配置（支持局域网/云端/本地大模型）
# =============================================================================
# 注意：不需要在本地下载模型，配置网络可达的大模型服务地址即可
# 支持：局域网 Ollama、公司内部 vLLM、云端 API、本地 Ollama

# AI供应商类型
# openai-compatible: 兼容OpenAI API的服务（Ollama、vLLM、LM Studio等）
# deepseek: DeepSeek API
# kimi: Kimi API
AI_PROVIDER=openai-compatible

# AI模型基础URL（填入你的大模型服务地址）
# 局域网 Ollama: http://192.168.1.100:11434/v1
# 本地 Ollama:   http://localhost:11434/v1
# DeepSeek 云:   https://api.deepseek.com/v1
# Kimi 云:       https://api.moonshot.cn/v1
AI_BASE_URL=http://localhost:11434/v1

# AI API密钥（本地模型通常不需要密钥，可留空）
# DeepSeek: 你的API Key
# Kimi: 你的API Key
AI_API_KEY=

# AI模型名称（根据本地部署的模型填写）
# 常用模型：
# - qwen2.5-14b-chat
# - qwen2.5-7b-chat
# - qwen2.5-3b-chat
# - deepseek-v2-chat
# - yi-34b-chat
AI_MODEL=qwen2.5-14b-chat

# 是否启用本地轻量识别（规则引擎）
AI_LOCAL_MODEL_ENABLED=true

# AI不可用时是否回退到规则识别
AI_FALLBACK_TO_RULES=true

# =============================================================================
# 解析引擎性能配置
# =============================================================================
# 最大并发模型数（同时运行的LLM数量，根据电脑内存调整）
# 建议：16GB内存设为1，32GB内存设为2，64GB内存设为3-4
LLM_MAX_CONCURRENT_MODELS=1

# 模型内存限制（MB），超过则降级到小模型
LLM_MEMORY_LIMIT_MB=8192

# 优先使用的模型（用于单引擎模式）
LLM_PREFERRED_MODEL=qwen2.5-14b-chat

# 降级模型（主模型内存不足时使用）
LLM_FALLBACK_MODEL=qwen2.5-7b-chat

# 单次调用超时（秒）
LLM_TIMEOUT_SECONDS=60

# =============================================================================
# 并行策略配置
# =============================================================================
# 是否启用双引擎并行解析（规则引擎 + LLM引擎同时解析）
LLM_ENABLE_PARALLEL_PARSING=true

# 并行解析总超时（秒）
LLM_PARALLEL_TIMEOUT_SECONDS=120

# =============================================================================
# 结果选择策略配置
# =============================================================================
# 结果选择模式：
# auto_best: 自动选择置信度最高的结果
# user_choose: 让用户选择
# hybrid: 高置信度自动采纳，低置信度提示用户确认
LLM_RESULT_SELECTION_MODE=auto_best

# 自动选择的置信度阈值（高于此值自动采纳）
LLM_CONFIDENCE_THRESHOLD_AUTO=0.8

# 需要用户确认的置信度阈值（低于此值提示用户）
LLM_CONFIDENCE_THRESHOLD_USER=0.6

# =============================================================================
# 多LLM引擎对比配置
# =============================================================================
# 是否启用多LLM引擎对比（同时调用多个模型，加权投票选择结果）
LLM_MULTI_ENGINE_ENABLED=false

# 对比模式：
# parallel_all: 并行调用所有引擎
# sequential_fallback: 顺序调用，失败时降级
# best_two: 只调用前两个最佳引擎
LLM_COMPARISON_MODE=parallel_all

# 对比策略：
# weighted_vote: 加权投票（按引擎权重计算得分）
# highest_confidence: 选择置信度最高的
# intersection: 取所有引擎一致的字段
# union_llm_best: 并集，优先采纳LLM结果
LLM_COMPARISON_STRATEGY=weighted_vote

# 对比引擎列表（逗号分隔，需已部署）
LLM_COMPARISON_ENGINES=qwen2.5-14b-chat,qwen2.5-7b-chat,deepseek-v2-chat

# 引擎权重（JSON格式，总和建议为1.0）
LLM_ENGINE_WEIGHTS={"qwen2.5-14b-chat":0.40,"qwen2.5-7b-chat":0.25,"deepseek-v2-chat":0.25}

# 字段一致率阈值（高于此值自动采纳对比结果）
LLM_AGREEMENT_THRESHOLD=0.7

# 是否保存所有LLM结果（用于后续分析）
LLM_SAVE_ALL_RESULTS=true

# =============================================================================
# 向量数据库配置（可选）
# =============================================================================
# Qdrant向量数据库地址
# QDRANT_URL=http://localhost:6333

# Redis缓存地址
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 文件存储配置
# =============================================================================
# 上传文件存储目录
UPLOAD_DIR=storage/uploads
